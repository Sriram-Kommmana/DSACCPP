class Main {
    public static void main(String[] args) {
        // find the bigger number without using any if else, ternary, bitwise etc
        int a = 10;
        int b = 5;
        
        int c = ((a + b) + Math.abs(a - b)) / 2;
        System.out.println("Bigger is " + c);
        int d = ((a + b) - Math.abs(a - b)) / 2;
        System.out.println("Smaller is " + d);
    }
}
